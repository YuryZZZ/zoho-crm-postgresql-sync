# ZOHO MAIL TO GCLOUD ARCHIVER - ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in your values

# GCP Configuration
PROJECT_ID="legalai-480809"
GCS_BUCKET_NAME="zoho-mail-archive-legalai-480809"
REGION="europe-west1"
SERVICE_NAME="zoho-mail-archiver-enhanced"

# Zoho OAuth Credentials (REQUIRED - get from https://api-console.zoho.com/)
ZOHO_CLIENT_ID="YOUR_ZOHO_CLIENT_ID_HERE"
ZOHO_CLIENT_SECRET="YOUR_ZOHO_CLIENT_SECRET_HERE"
ZOHO_REFRESH_TOKEN="YOUR_ZOHO_REFRESH_TOKEN_HERE"
ZOHO_ACCOUNT_ID="YOUR_ZOHO_ACCOUNT_ID_HERE"

# Optional: Service Account Names
RUNTIME_SA_NAME="zoho-archiver-enhanced"
SCHEDULER_SA_NAME="zoho-archiver-scheduler-enhanced"

# Optional: Scheduling
SCHEDULE="*/10 * * * *"  # Every 10 minutes
TIME_ZONE="Europe/Paris"

# Optional: Secret Names (if using different names in Secret Manager)
SECRET_ZOHO_CLIENT_ID="zoho-client-id"
SECRET_ZOHO_CLIENT_SECRET="zoho-client-secret"
SECRET_ZOHO_REFRESH_TOKEN="zoho-refresh-token"
SECRET_ZOHO_ACCOUNT_ID="zoho-account-id"

# Optional: Artifact Registry
ARTIFACT_REPO="zoho-archiver-enhanced"

# Optional: Archiver Configuration
GCS_BASE_PATH="zoho-archive-enhanced"
MODE="continuous"
LOG_LEVEL="info"
LOG_FORMAT="json"